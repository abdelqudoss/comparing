@{
    ViewData["Title"] = "Home";
}

<div class="text-center mb-5">
    <h1 class="display-3 fw-bold text-primary mb-3">📊 Excel Compare System</h1>
    <p class="lead text-muted">High-performance comparison tool for large Excel datasets (up to 2M rows)</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-6">
        <div class="card h-100 border-primary">
            <div class="card-body p-4">
                <h3 class="card-title mb-3">📤 Upload Files</h3>
                <p class="card-text mb-3">Upload your Sent and Received Excel files for high-speed processing.</p>
                <ul class="list-unstyled">
                    <li class="mb-2">✓ Supports up to 2,000,000 rows</li>
                    <li class="mb-2">✓ Streaming Excel reader</li>
                    <li class="mb-2">✓ Bulk database insertion</li>
                    <li class="mb-2">✓ Progress tracking</li>
                </ul>
                <a asp-controller="Upload" asp-action="Index" class="btn btn-primary btn-lg mt-3">
                    Start Upload →
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100 border-success">
            <div class="card-body p-4">
                <h3 class="card-title mb-3">🔍 Compare Data</h3>
                <p class="card-text mb-3">Compare Sent vs Received batches to identify data differences.</p>
                <ul class="list-unstyled">
                    <li class="mb-2">✓ New records detection</li>
                    <li class="mb-2">✓ Missing records identification</li>
                    <li class="mb-2">✓ Changed records tracking</li>
                    <li class="mb-2">✓ SQL-based comparison engine</li>
                </ul>
                <a asp-controller="Comparison" asp-action="Index" class="btn btn-success btn-lg mt-3">
                    Start Comparison →
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card shadow">
    <div class="card-body p-4">
        <h4 class="mb-4 text-center">System Features</h4>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="text-center">
                    <div class="display-6 mb-3">⚡</div>
                    <h5 class="fw-bold">Performance Optimized</h5>
                    <ul class="list-unstyled text-muted">
                        <li>SqlBulkCopy for fast inserts</li>
                        <li>Streaming file reading</li>
                        <li>Batch processing (10K rows)</li>
                        <li>Indexed database queries</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center">
                    <div class="display-6 mb-3">🎯</div>
                    <h5 class="fw-bold">Smart Comparison</h5>
                    <ul class="list-unstyled text-muted">
                        <li>Composite key: mem + nid</li>
                        <li>Track member_rank changes</li>
                        <li>Track ref_sn changes</li>
                        <li>SQL JOIN-based detection</li>
                    </ul>
                </div>
            </div>
            <div class="col-md-4">
                <div class="text-center">
                    <div class="display-6 mb-3">🏗️</div>
                    <h5 class="fw-bold">Clean Architecture</h5>
                    <ul class="list-unstyled text-muted">
                        <li>Layered architecture</li>
                        <li>Repository pattern</li>
                        <li>Dependency injection</li>
                        <li>Entity Framework Core</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
