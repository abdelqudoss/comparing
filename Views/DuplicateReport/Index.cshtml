@model IEnumerable<ExcelCompare.Domain.Entities.UploadDuplicate>

@{
    ViewData["Title"] = "Duplicate Records Report";
    var filterType = ViewBag.FilterType as string;
    var totalDuplicates = ViewBag.TotalDuplicates as int? ?? 0;
    var withinFileCount = ViewBag.WithinFileCount as int? ?? 0;
    var crossBatchCount = ViewBag.CrossBatchCount as int? ?? 0;
}

<div class="container mt-4">
    <h2><i class="bi bi-exclamation-triangle"></i> Duplicate Records Report</h2>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h6 class="text-muted">Total Duplicates</h6>
                    <h2 class="text-primary">@totalDuplicates.ToString("N0")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h6 class="text-muted">Within File</h6>
                    <h2 class="text-danger">@withinFileCount.ToString("N0")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body text-center">
                    <h6 class="text-muted">Cross Batch</h6>
                    <h2 class="text-warning">@crossBatchCount.ToString("N0")</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5>Filter Duplicates</h5>
            <div class="btn-group" role="group">
                <a href="@Url.Action("Index")" class="btn @(string.IsNullOrEmpty(filterType) ? "btn-primary" : "btn-outline-primary")">
                    All
                </a>
                <a href="@Url.Action("Index", new { filterType = "withinfile" })" 
                   class="btn @(filterType == "withinfile" ? "btn-danger" : "btn-outline-danger")">
                    Within File Only
                </a>
                <a href="@Url.Action("Index", new { filterType = "crossbatch" })" 
                   class="btn @(filterType == "crossbatch" ? "btn-warning" : "btn-outline-warning")">
                    Cross Batch Only
                </a>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Upload Batch</th>
                    <th>Type</th>
                    <th>Match Field</th>
                    <th>Match Value</th>
                    <th>Conflicting Batch</th>
                    <th>Detected At</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var dup in Model)
                    {
                        <tr>
                            <td>@dup.Id</td>
                            <td>
                                <a href="@Url.Action("Index", "Upload")" class="text-decoration-none">
                                    <strong>Batch @dup.UploadBatchId</strong>
                                </a>
                                <br>
                                <small class="text-muted">@dup.UploadBatch?.FileName</small>
                            </td>
                            <td>
                                @if (dup.ConflictingBatchId == null)
                                {
                                    <span class="badge bg-danger">Within File</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Cross Batch</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-secondary">@dup.MatchedField</span>
                            </td>
                            <td>
                                <code>@dup.MatchedValue</code>
                            </td>
                            <td>
                                @if (dup.ConflictingBatchId != null)
                                {
                                    <a href="@Url.Action("Index", "Upload")" class="text-decoration-none">
                                        <strong>Batch @dup.ConflictingBatchId</strong>
                                    </a>
                                    <br>
                                    <small class="text-muted">@dup.ConflictingBatch?.FileName</small>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <small>@dup.DetectedAt.ToString("yyyy-MM-dd HH:mm:ss")</small>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">
                            @if (string.IsNullOrEmpty(filterType))
                            {
                                <p>No duplicates found! 🎉</p>
                            }
                            else
                            {
                                <p>No duplicates found for this filter.</p>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model != null && Model.Count() >= 500)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Showing first 500 duplicates. Use filters to narrow down results.
        </div>
    }
</div>
