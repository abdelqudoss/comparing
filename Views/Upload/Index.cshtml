@model IEnumerable<ExcelCompare.Domain.Entities.UploadBatch>

@{
    ViewData["Title"] = "Upload Excel Files";
}

<div class="container mt-4">
    <h2>Upload Excel Files</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Upload Failed</strong>
            <pre style="white-space: pre-wrap; background-color: transparent; border: none; padding: 0; margin-top: 10px; font-family: inherit;">@TempData["Error"]</pre>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Upload New File</h5>
            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-4">
                        <label for="file" class="form-label">Select Excel File</label>
                        <input type="file" class="form-control" id="file" name="file" accept=".xlsx,.xls" required>
                    </div>
                    <div class="col-md-3">
                        <label for="fileType" class="form-label">File Type</label>
                        <select class="form-select" id="fileType" name="fileType" required>
                            <option value="">Select Type</option>
                            <option value="Sent">Sent</option>
                            <option value="Received">Received</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">Upload</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <h4>Upload History</h4>
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Type</th>
                    <th>File Type</th>
                    <th>File Name</th>
                    <th>Upload Date</th>
                    <th>Total Rows</th>
                    <th>Duplicates</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var batch in Model)
                    {
                        <tr>
                            <td>
                                <a href="#" class="text-decoration-none" title="View batch details">
                                    <strong>@batch.Id</strong>
                                </a>
                            </td>
                            <td>
                                @if (batch.IsUpdate)
                                {
                                    <span class="badge bg-warning text-dark" title="This is an update to batch @batch.OriginalBatchId">
                                        <i class="bi bi-arrow-clockwise"></i> Update
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">
                                        <i class="bi bi-plus-circle"></i> New
                                    </span>
                                }
                            </td>
                            <td>
                                <span class="badge @(batch.FileType == "Sent" ? "bg-info" : "bg-success")">
                                    @batch.FileType
                                </span>
                            </td>
                            <td>@batch.FileName</td>
                            <td>@batch.UploadedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@batch.TotalRows.ToString("N0")</td>
                            <td>
                                <span class="text-muted">-</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">No uploads yet</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
